BuildSection('TyrannyLord', function()
    local SelectedPassPlayer  = nil
    local ListedItemsToBuyBack = {}
    local TLAutoDupe, TLCooldown = false, false

    local function GetHeldTool()
        local Character = LocalPlayer.Character
        if not Character then return nil end
        local Tool = Character:FindFirstChildOfClass("Tool")
        if not Tool then return nil end
        if Tool.Name == "Fist" or Tool.Name == "Phone" then return nil end
        return Tool
    end

    local function GetRandomNearbyPlayer(maxRange)
        local Character = LocalPlayer.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")
        if not Root then return nil end
        local Nearby = {}
        for _, Player in ipairs(Players:GetPlayers()) do
            if Player == LocalPlayer then continue end
            local OtherRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if not OtherRoot then continue end
            if (Root.Position - OtherRoot.Position).Magnitude <= maxRange then
                table.insert(Nearby, Player.Name)
            end
        end
        if #Nearby == 0 then return nil end
        return Nearby[math.random(1, #Nearby)]
    end

    -- Reuse the "Dupe Actions" box created under Player Options; fall back to a
    -- fresh one if the Players section didn't build for some reason.
    local SafeActions = DupeActionsBox or Tabs.Lord:AddLeftGroupbox('Dupe Actions')

    -- One-shot buy-back: re-purchases every item you currently have listed on the
    -- market in a single sweep (guarded against overlapping runs). Used by the
    -- "Buy Back Listed Items" toggle and fired automatically when Auto Dupe is
    -- switched off.
    local function BuyBackListed()
        if Config.BuyBackRunning then return end
        Config.BuyBackRunning = true
        task.spawn(function()
            local Player = Players.LocalPlayer
            local Character = Player.Character or Player.CharacterAdded:Wait()
            local Humanoid = Character and Character:FindFirstChild("Humanoid")
            local BuyItemRemote = ReplicatedStorage:WaitForChild("BuyItemRemote")

            -- Collect every market listing owned by you (name + SpecialId).
            local toBuy = {}
            for _, v in pairs(ReplicatedStorage.MarketItems:GetDescendants()) do
                if v:IsA("StringValue") and v.Name == "owner" and v.Value == Player.Name and v.Parent then
                    local id = v.Parent:GetAttribute("SpecialId")
                    if id then table.insert(toBuy, { name = v.Parent.Name, id = id }) end
                end
            end

            if #toBuy == 0 then
                library.notifications:create_notification({ name = "Tyranny.Exe", info = "No listed items to buy back.", lifetime = 5 })
                Config.BuyBackRunning = false
                return
            end

            local BoughtCount = 0
            for _, item in ipairs(toBuy) do
                if Humanoid and Humanoid.Health == 0 then break end
                BuyItemRemote:FireServer(item.name, "Remove", item.id)
                BoughtCount += 1
                task.wait(2.5)
            end

            library.notifications:create_notification({ name = "Tyranny.Exe", info = "Bought back " .. tostring(BoughtCount) .. " listed item(s).", lifetime = 5 })
            Config.BuyBackRunning = false
        end)
    end

    SafeActions:AddToggle('autodupecurrentitem_tl', { Text = 'Auto Dupe Current Item', Default = false,
        Callback = function(state)
            TLAutoDupe = state
            if not state then
                -- Stopped duping — if "Buy Back Listed Items" is on, automatically
                -- re-buy everything that got listed during the dupe. Short delay so
                -- the final list action settles before the sweep starts.
                if Config.BuyBackListedItems then
                    task.spawn(function() task.wait(1) BuyBackListed() end)
                end
                return
            end
            task.spawn(function()
                while TLAutoDupe do
                    task.wait(0.5)
                    if TLCooldown then continue end
                    TLCooldown = true

                    local Player = Players.LocalPlayer
                    local Backpack = Player.Backpack
                    local Character = Player.Character
                    if not Character or not Character:FindFirstChild("Humanoid") then TLCooldown = false continue end

                    local Tool = Character:FindFirstChildOfClass("Tool")
                    if not Tool then
                        library.notifications:create_notification({ name = "Xylo.Ware", info = "No tool held! Hold one to auto-dupe.", lifetime = 7 })
                        TLCooldown = false
                        task.wait(1)
                        continue
                    end

                    local ToolName = Tool.Name
                    local count = 0
                    for _, item in ipairs(Backpack:GetChildren()) do
                        if item:IsA("Tool") and item.Name == ToolName then count += 1 end
                    end
                    if Character:FindFirstChild(ToolName) then count += 1 end

                    if count > 3 then
                        library.notifications:create_notification({ name = "Xylo.Ware", info = "More than 3 of this tool exists! Move extras before continuing.", lifetime = 7 })
                        TLCooldown = false
                        task.wait(2)
                        continue
                    end

                    Character.Humanoid:UnequipTools()
                    local ToolId
                    local Connection = ReplicatedStorage.MarketItems.ChildAdded:Connect(function(item)
                        if item.Name == ToolName and item:WaitForChild("owner").Value == Player.Name then
                            ToolId = item:GetAttribute("SpecialId")
                        end
                    end)

                    spawn(function() ReplicatedStorage.ListWeaponRemote:FireServer(ToolName, 1000000) end)
                    task.wait(0.26)
                    spawn(function() ReplicatedStorage.BackpackRemote:InvokeServer("Store", ToolName) end)
                    task.wait(3)
                    if ToolId then spawn(function() ReplicatedStorage.BuyItemRemote:FireServer(ToolName, "Remove", ToolId) end) end
                    spawn(function() ReplicatedStorage.BackpackRemote:InvokeServer("Grab", ToolName) end)
                    if Connection then Connection:Disconnect() end
                    task.wait(1.5)

                    -- List the extra copy back to the market. Bounded so a FULL
                    -- market (listing cap reached) can't hang the cycle forever:
                    -- if the listing keeps getting rejected we bail out instead of
                    -- spinning, so the outer loop resets and keeps grabbing.
                    local listAttempts = 0
                    while TLAutoDupe do
                        local dupCount = 0
                        for _, item in ipairs(Backpack:GetChildren()) do
                            if item:IsA("Tool") and item.Name == ToolName then dupCount += 1 end
                        end
                        if Character:FindFirstChild(ToolName) then dupCount += 1 end
                        if dupCount == 2 then
                            listAttempts += 1
                            if listAttempts > 4 then
                                library.notifications:create_notification({ name = "Xylo.Ware", info = "Market won't accept the listing (full?). Skipping — turn on Buy Back Listed Items to clear it.", lifetime = 7 })
                                break
                            end
                            local ListedToolId
                            local ListConnection = ReplicatedStorage.MarketItems.ChildAdded:Connect(function(item)
                                if item.Name == ToolName then
