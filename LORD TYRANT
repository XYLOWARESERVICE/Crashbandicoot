        -- clone yet — the camera stays on it so you don't see the real character
        -- sitting back at the start spot during the Teleport() anti-cheat settle.
        local dest
        if GhostClone then
            local gHrp = GhostClone:FindFirstChild("HumanoidRootPart")
            if gHrp then dest = gHrp.CFrame end
        end
        local theClone = GhostClone
        GhostClone = nil

