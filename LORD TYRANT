BuildSection('Safe', function()
    local function ResolveSafeCFrame(Safe)
        if not Safe then return nil end
        local Clicker = Safe:FindFirstChild("ChestClicker")
        if Clicker and Clicker:IsA("BasePart") then return Clicker.CFrame end
        local Ok, Pivot = pcall(function() return Safe:GetPivot() end)
        if Ok and Pivot then return Pivot end
        return nil
    end

    local SafeItem = AF.SafeSelected

    SafeItem:AddDropdown('SafeSelectedItem_TheBronx', {
        Values = {}, Default = nil, Text = 'Backpack Item', AllowNull = true,
        Callback = function(state)
            task.spawn(function()
                if not state then return end
                local Safe = GetWorkingSafe()
                local OldCFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
                if not Safe then
                    return library.notifications:create_notification({ name = "Tyranny.Exe", info = "Couldn't find your house safe.", lifetime = 5 })
                end
                pcall(Teleport, ResolveSafeCFrame(Safe))
                local Tool = tostring(state)
                LocalPlayer.Character:WaitForChild("Humanoid"):UnequipTools()
                local ItemSafed = false
                local C
                C = LocalPlayer.Backpack.ChildRemoved:Connect(function(Child)
                    if tostring(Child) == Tool then ItemSafed = true C:Disconnect() end
                end)
                task.delay(3, function() ItemSafed = true end)
                task.wait(0.5)
                ReplicatedStorage.Inventory:FireServer("Change", Tool, "Backpack", Safe)
                repeat task.wait() until ItemSafed == true
                pcall(Teleport, OldCFrame)
                library.notifications:create_notification({ name = "Tyranny.Exe", info = "Successfully safed " .. state .. "!", lifetime = 5 })
            end)
        end,
    })

    local function RefreshSafeList()
        -- Backpack is destroyed + recreated on respawn, so it can be momentarily
        -- nil. Guard against that instead of indexing LocalPlayer.Backpack directly.
        local Backpack = LocalPlayer:FindFirstChild("Backpack")
        if not Backpack then return end
        local Items = {}
        for _, Value in Backpack:GetChildren() do
            if Value:IsA("Tool") then table.insert(Items, Value.Name) end
        end
        table.sort(Items)
        Options.SafeSelectedItem_TheBronx:SetValues(Items)
    end
    task.spawn(RefreshSafeList)
    -- Re-wire the Backpack listeners on every respawn (the old Backpack instance
    -- is gone, so connections to it would silently stop firing / error).
    local function HookBackpack()
        local Backpack = LocalPlayer:WaitForChild("Backpack")
        Backpack.ChildAdded:Connect(RefreshSafeList)
        Backpack.ChildRemoved:Connect(RefreshSafeList)
        pcall(RefreshSafeList)
    end
    task.spawn(HookBackpack)
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1) pcall(HookBackpack)
    end)

    local TakeItem = AF.TakeSelected

    TakeItem:AddDropdown('TakeSelectedItem_TheBronx', {
        Values = {}, Default = nil, Text = 'Safe Item', AllowNull = true,
        Callback = function(state)
            task.spawn(function()
                if not state then return end
                local Safe = GetWorkingSafe()
                local OldCFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
                if not Safe then
                    return library.notifications:create_notification({ name = "Tyranny.Exe", info = "Couldn't find your house safe.", lifetime = 5 })
                end
                pcall(Teleport, ResolveSafeCFrame(Safe))
                local Tool = tostring(state)
                local ItemTaken = false
                local C
                C = LocalPlayer.Backpack.ChildAdded:Connect(function(Child)
                    if tostring(Child) == Tool then ItemTaken = true C:Disconnect() end
                end)
                task.delay(3, function() ItemTaken = true end)
                task.wait(0.5)
                ReplicatedStorage.Inventory:FireServer("Change", Tool, "Inv", Safe)
                repeat task.wait() until ItemTaken == true
                pcall(Teleport, OldCFrame)
                library.notifications:create_notification({ name = "Tyranny.Exe", info = "Successfully took " .. state .. " from safe!", lifetime = 5 })
            end)
        end,
    })

    local function RefreshTakeList()
        local Items = {}
        for _, Value in LocalPlayer:WaitForChild("InvData"):GetChildren() do
            table.insert(Items, Value.Name)
        end
        table.sort(Items)
        Options.TakeSelectedItem_TheBronx:SetValues(Items)
    end
    task.spawn(RefreshTakeList)
    LocalPlayer:WaitForChild("InvData").ChildAdded:Connect(RefreshTakeList)
    LocalPlayer.InvData.ChildRemoved:Connect(RefreshTakeList)
end)

