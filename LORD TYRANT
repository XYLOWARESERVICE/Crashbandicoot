BuildSection('Misc', function()
    local Farm = AF.Farming

    -- The four teleport-farms each yank your character to a different location.
    -- Running more than one at once makes their loops fight over your position.
    -- It's most visible right after a respawn: while dead, every farm loop bails
    -- at its "Health == 0" guard and idles in sync, then on respawn they all
    -- clear the guard on the same frame and fire at once. Make them mutually
    -- exclusive (UI-only; backend untouched) so only one can ever be active.
    local FarmToggleFlags = {
        'FarmConstruction_TheBronx', 'FarmBank_TheBronx',
        'FarmStudio_TheBronx', 'FarmDumpsters_TheBronx',
    }
    local SwitchingFarms = false
    local function MakeExclusive(enabledFlag)
        if SwitchingFarms then return end
        SwitchingFarms = true
        for _, flag in ipairs(FarmToggleFlags) do
            if flag ~= enabledFlag and Toggles[flag] then
                Toggles[flag]:SetValue(false)
            end
        end
        SwitchingFarms = false
    end

    Farm:AddToggle('FarmConstruction_TheBronx', { Text = 'Auto Construction', Default = false,
        Callback = function(state)
            Config.TheBronx.Farms.FarmConstructionJob = state
            if state then MakeExclusive('FarmConstruction_TheBronx') end
        end })
    Farm:AddToggle('FarmBank_TheBronx', { Text = 'Auto Bank Robbery', Default = false,
        Callback = function(state)
            Config.TheBronx.Farms.FarmBank = state
            if state then MakeExclusive('FarmBank_TheBronx') end
        end })
    Farm:AddToggle('FarmStudio_TheBronx', { Text = 'Auto Studio Robbery', Default = false,
        Callback = function(state)
            Config.TheBronx.Farms.FarmStudio = state
            if state then MakeExclusive('FarmStudio_TheBronx') end
        end })
    Farm:AddToggle('FarmDumpsters_TheBronx', { Text = 'Auto Dumpsters', Default = false,
        Callback = function(state)
            Config.TheBronx.Farms.FarmTrash = state
            if state then MakeExclusive('FarmDumpsters_TheBronx') end
        end })

    local Manual = AF.ManualFarms

    Manual:AddToggle('FarmDroppedMoney_TheBronx', { Text = 'Auto Collect Dropped Cash', Default = false,
        Callback = function(state) Config.TheBronx.Farms.CollectDroppedMoney = state end })
    Manual:AddToggle('FarmDroppedLoot_TheBronx', { Text = 'Auto Collect Dropped Bags', Default = false,
        Callback = function(state) Config.TheBronx.Farms.CollectDroppedLoot = state end })

    Manual:AddButton({ Text = 'Clean All Filthy Money', Func = function()
        task.spawn(function()
            if LocalPlayer.stored.FilthyStack.Value == 0 then
                return library.notifications:create_notification({ name = "Tyranny.Exe", info = "You have no filthy money!", lifetime = 7.5 })
            end
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
            if not LocalPlayer.Character:FindFirstChild("Humanoid") or LocalPlayer.Character.Humanoid.Health == 0 then return end

            local Cleaner = GetGoodCleaner()
            if not Cleaner then
                return library.notifications:create_notification({ name = "Tyranny.Exe", info = "Could not find a valid cleaner!", lifetime = 7.5 })
