        driveSeat:Sit(character.Humanoid)
        nearestCar:SetAttribute("Usable", true)
        library.notifications:create_notification({ name = "Xylo.Ware", info = "Car spawned successfully!", lifetime = 3 })
    end })

    local MoreExtra = AF.MoreExtra
    local function ShopBuy(Item) ReplicatedStorage.ShopRemote:InvokeServer(Item) end
