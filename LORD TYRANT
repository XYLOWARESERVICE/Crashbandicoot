-- License time-left readout, taken from the Luarmor loader's LRM_SecondsLeft
-- global (seconds until the key expires). Converted seconds -> whole days, or
-- shown as "Lifetime" when there's no expiry (nil / math.huge). This replaces the
-- old hardcoded "Lifetime" in the title bar.
--
-- The License text is also COLORED by key tier, inferred from the days remaining:
--   • Lifetime (no expiry)   -> gold
--   • Monthly (> 7 days left) -> green
--   • Weekly  (2–7 days left) -> blue
--   • Daily   (<= 1 day left) -> red
-- Note: LRM_SecondsLeft is time REMAINING, not the original plan length, so a
-- monthly key near its end will read/colour as a shorter tier — that's expected.
local LRM_Secs = LRM_SecondsLeft or (getgenv and getgenv().LRM_SecondsLeft)
if type(LRM_Secs) ~= "number" then LRM_Secs = math.huge end

local LICENSE_TEXT, LICENSE_COLOR
if LRM_Secs == math.huge then
    LICENSE_TEXT  = "Lifetime"
    LICENSE_COLOR = "rgb(255,200,60)"   -- gold
else
    local days = math.floor(((LRM_Secs / 60) / 60) / 24)
    LICENSE_TEXT = days .. " Days"
    if days > 7 then
        LICENSE_COLOR = "rgb(85,255,127)"   -- green  (monthly / long)
    elseif days >= 2 then
        LICENSE_COLOR = "rgb(90,160,255)"   -- blue   (weekly)
    else
        LICENSE_COLOR = "rgb(255,80,80)"    -- red    (daily / expiring)
    end
end

