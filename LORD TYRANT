        local maxAmt = math.max(1, owned)
        slider.Max = maxAmt
        slider.Text = SelectedPassGun
            and ('Pass Amount (own ' .. owned .. ')')
            or 'Pass Amount'
        -- Re-clamp + redisplay against the new max.
        slider:SetValue(math.clamp(slider.Value, slider.Min, maxAmt))
    end

