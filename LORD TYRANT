                end
                Config.TheBronx.MoneyAmount = Config.TheBronx.CustomDropAmount
            end
            Config.TheBronx.AutoDrop = state
        end })

    -- Auto Deposit / Withdraw use the amounts from the inputs above
    -- (defaults 30K / 90K, matching the labels).
    Money:AddToggle('AutoDeposit30K_TB3', { Text = 'Auto Deposit', Default = false,
        Callback = function(state) Config.TheBronx.AutoDeposit = state end })
    Money:AddToggle('AutoWithdraw90K_TB3', { Text = 'Auto Withdraw', Default = false,
        Callback = function(state) Config.TheBronx.AutoWithdraw = state end })

    local Vehicle = AF.Vehicle
    Vehicle:AddToggle('EnableSpeed_TB3', { Text = 'Enabled - Speed', Default = false,
        Callback = function(state) Config.TheBronx.VehicleModifications.SpeedEnabled = state end })
    Vehicle:AddToggle('EnableBreak_TB3', { Text = 'Enabled - Break', Default = false,
        Callback = function(state) Config.TheBronx.VehicleModifications.BreakEnabled = state end })
    Vehicle:AddToggle('EnableVehicleFly_TB3', { Text = 'Enabled - Vehicle Fly', Default = false,
        Callback = function(state)
            if state then
                local Cam = workspace.CurrentCamera
                local CurrentVelocity = Vector3.new(0, 0, 0)
                local FlightSpeed, FlightAcceleration, SpeedKeyMultiplier = 256, 4, 3
                local SpeedKey = Enum.KeyCode.LeftControl
                workspace.Changed:Connect(function() Cam = workspace.CurrentCamera end)
                Config.TheBronx.VehicleModifications.VehicleFlyConnection = RunService.Heartbeat:Connect(function(delta)
                    if not Config.TheBronx.VehicleModifications.VehicleFlyEnabled then return end
                    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
                    local BaseVelocity = Vector3.new(0, 0, 0)
                    if not UserInputService:GetFocusedTextBox() then
                        if UserInputService:IsKeyDown(Enum.KeyCode.W) then BaseVelocity += Cam.CFrame.LookVector * FlightSpeed end
                        if UserInputService:IsKeyDown(Enum.KeyCode.A) then BaseVelocity -= Cam.CFrame.RightVector * FlightSpeed end
                        if UserInputService:IsKeyDown(Enum.KeyCode.S) then BaseVelocity -= Cam.CFrame.LookVector * FlightSpeed end
                        if UserInputService:IsKeyDown(Enum.KeyCode.D) then BaseVelocity += Cam.CFrame.RightVector * FlightSpeed end
                        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then BaseVelocity += Vector3.new(0, 1, 0) * FlightSpeed end
                        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then BaseVelocity -= Vector3.new(0, 1, 0) * FlightSpeed end
                        if UserInputService:IsKeyDown(SpeedKey) then BaseVelocity *= SpeedKeyMultiplier end
                    end
                    pcall(function()
                        local Humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if not Humanoid then return end
                        local SeatPart = Humanoid.SeatPart
                        if not SeatPart or not SeatPart:IsA("VehicleSeat") then return end
                        CurrentVelocity = CurrentVelocity:Lerp(BaseVelocity, math.clamp(delta * FlightAcceleration, 0, 1))
                        SeatPart.AssemblyLinearVelocity = CurrentVelocity
                        SeatPart.AssemblyAngularVelocity = Vector3.zero
                    end)
                end)
                Config.TheBronx.VehicleModifications.VehicleFlyEnabled = true
                library.notifications:create_notification({ name = "Xylo.Ware", info = "Vehicle Fly enabled!", lifetime = 3 })
            else
                Config.TheBronx.VehicleModifications.VehicleFlyEnabled = false
                if Config.TheBronx.VehicleModifications.VehicleFlyConnection then
                    Config.TheBronx.VehicleModifications.VehicleFlyConnection:Disconnect()
                    Config.TheBronx.VehicleModifications.VehicleFlyConnection = nil
                end
                library.notifications:create_notification({ name = "Xylo.Ware", info = "Vehicle Fly disabled!", lifetime = 3 })
            end
        end })
    Vehicle:AddSlider('SpeedAmount_TB3', { Text = 'Speed Amount', Default = 10, Min = 1, Max = 200, Rounding = 0, Suffix = ' Power',
        Callback = function(state) Config.TheBronx.VehicleModifications.SpeedValue = state / 1000 end })
    Vehicle:AddSlider('BreakAmount_TB3', { Text = 'Break Amount', Default = 10, Min = 1, Max = 200, Rounding = 0, Suffix = ' Power',
