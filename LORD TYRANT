local CanUpvalueAmmo = (type(getgc) == "function" and type(getsenv) == "function"
    and type(getfenv) == "function" and debug and type(debug.getupvalues) == "function"
    and type(debug.setupvalue) == "function")

-- Low-sUNC infinite ammo: require the gun's Setting module and flip its ammo
-- flags directly on the live config table (the same table GunScript reads).
local function ApplyModuleAmmo(tool, on)
    if not tool then return end
    local m = tool:FindFirstChild("Setting")
    if not (m and m:IsA("ModuleScript")) then m = tool:FindFirstChildOfClass("ModuleScript") end
    if not (m and m:IsA("ModuleScript")) then return end
    local ok, cfg = pcall(require, m)
    if not ok or type(cfg) ~= "table" then return end
    if on then
        pcall(function() cfg.LimitedAmmoEnabled = false end)
        pcall(function() cfg.LimitedAmmo = false end)
        pcall(function() if cfg.AmmoPerMag then cfg.AmmoPerMag = math.max(tonumber(cfg.AmmoPerMag) or 0, 999) end end)
        pcall(function() if cfg.MagSize then cfg.MagSize = math.max(tonumber(cfg.MagSize) or 0, 999) end end)
    end
end

