                            task.wait(0.05)
                        end
                        if not Equipped then return end
                        -- Only fire /passto if the gun is actually in hand right now
                        local InHand = Character:FindFirstChildOfClass("Tool")
                        if not InHand or InHand.Name ~= LockedToolName then return end
                        local ChatEvents = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
                        if ChatEvents and ChatEvents:FindFirstChild("SayMessageRequest") then
                            ChatEvents.SayMessageRequest:FireServer("/passto " .. TargetName, "All")
                        else
                            TextChatService.TextChannels.RBXGeneral:SendAsync("/passto " .. TargetName)
                        end
                        task.wait(0.35)
                        pcall(function() BackpackRemote:InvokeServer("Grab", LockedToolName) end)
                        task.wait(0.2)
                        local ReEquip = Character:FindFirstChild(LockedToolName) or Backpack:FindFirstChild(LockedToolName)
                        if ReEquip then Humanoid:EquipTool(ReEquip) end
                    end)
                    task.wait(1.6)
                end
            end)
        end,
    })

    SafeActions:AddLabel('Hold the item you want to share, stay close to another player, then toggle on.', true)
end)

