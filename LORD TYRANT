                    local OwnerVal = ReadOwnerValue(House)
                    if OwnerVal == nil then return false end
                    if typeof(OwnerVal) == "Instance" and OwnerVal:IsA("Player") then
                        return OwnerVal == LocalPlayer
                    elseif type(OwnerVal) == "string" then
                        return OwnerVal == LocalPlayer.Name or OwnerVal == LocalPlayer.DisplayName or OwnerVal == tostring(LocalPlayer.UserId)
