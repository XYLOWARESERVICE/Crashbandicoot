        Placeholder = '30000',
        Callback = function(value)
            local n = tonumber(value)
            if n then Config.TheBronx.DepositAmount = n end
        end })

    -- Two drop modes that share the backend Auto Drop loop (which reads
    -- MoneyAmount + AutoDrop). They're mutually exclusive so they can't fight over
