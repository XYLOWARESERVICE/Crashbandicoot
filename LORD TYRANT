        end,
    })

    -- Ghost Walk move speed — sets the WalkSpeed of the local clone you scout with.
    -- The clone is client-only, so this isn't seen by the server/anti-cheat; you
    -- can crank it without the position check flagging (only the final teleport
    -- back goes through the bypass).
    CharMods:AddSlider('GhostWalkSpeed_TheBronx', {
        Text = 'Ghost Walk Speed', Default = 24, Min = 8, Max = 250, Rounding = 0, Suffix = ' spd',
        Callback = function(v) GhostSpeed = v end,
    })

    -- ── Ghost Fly ────────────────────────────────────────────────────────
    -- Same decoy/clone trick as Ghost Walk, but the clone FLIES instead of
    -- walking. Toggle ON: your real character anchors in place (the decoy the
    -- server/others see), a LOCAL clone is spawned, and you fly that clone freely
    -- in 3D — WASD moves along the camera, Space goes up, Ctrl/Shift goes down.
    -- The clone is client-only so flight never trips the anti-cheat. Toggle OFF:
    -- the real character teleports (through the valary bypass) to wherever you
    -- flew, then the clone is removed. Shares GhostClone/GhostConn + StopGhost with
    -- Ghost Walk, so only one of the two can run at a time.
    CharMods:AddToggle('GhostFly_TheBronx', {
        Text = 'Ghost Fly', Default = false,
        Callback = function(state)
            if not state then
                StopGhost(true)
                return
            end

            -- Can't run both at once — turn Ghost Walk off if it's on.
            if Toggles.GhostWalk_TheBronx and Toggles.GhostWalk_TheBronx.Value then
                Toggles.GhostWalk_TheBronx:SetValue(false)
            end

            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if not (char and hrp and hum) then
                Toggles.GhostFly_TheBronx:SetValue(false)
                return
            end

            -- 1) Clone the character to use as the controllable ghost body.
            char.Archivable = true
            GhostClone = char:Clone()
            char.Archivable = false
            GhostClone.Name = "TyrannyGhostBody"

            for _, d in ipairs(GhostClone:GetDescendants()) do
                if d:IsA("Tool") then
                    d:Destroy()
                elseif d:IsA("LocalScript") or d:IsA("Script") then
                    pcall(function() d.Disabled = true end)
                end
            end
            GhostClone.Parent = workspace

            local gHum = GhostClone:FindFirstChildOfClass("Humanoid")
            local gHrp = GhostClone:FindFirstChild("HumanoidRootPart")
            if not (gHum and gHrp) then
                StopGhost(false)
                Toggles.GhostFly_TheBronx:SetValue(false)
                return
            end

            -- 2) Freeze the REAL character in place (server + others see you here).
            for _, p in ipairs(char:GetDescendants()) do
                if p:IsA("BasePart") then p.Anchored = true end
            end

            -- 3) Set the clone up to float SMOOTHLY. The old version anchored only
            --    the root and left every limb physics-simulated, so the limbs
            --    dragged/jittered behind as you moved (the "sticky" feel). Now:
            --      • anchor the root (we drive it by CFrame),
            --      • make every OTHER part massless + non-colliding so the welded
            --        body follows the root instantly with no physics drag and can't
            --        catch on world geometry,
            --      • PlatformStand + AutoRotate off so the Humanoid state machine
            --        doesn't fight the CFrame we set.
            gHum.PlatformStand = true
            gHum.AutoRotate = false
            gHrp.Anchored = true
            for _, p in ipairs(GhostClone:GetDescendants()) do
                if p:IsA("BasePart") and p ~= gHrp then
                    p.CanCollide = false
                    p.Massless = true
                end
            end

            -- 4) Camera follows the ghost; fly the root CFrame each frame from raw
            --    key state. WASD move on a flat horizontal plane, Space = up,
            --    LeftControl/LeftShift = down.
            Camera.CameraSubject = gHum

            -- Keep the body's upright rotation as the fallback when the camera is
            -- pointed straight up/down (flat look vector ~ 0).
            local baseRot = gHrp.CFrame - gHrp.CFrame.Position

            GhostConn = RunService.RenderStepped:Connect(function(dt)
                if not (GhostClone and gHrp and gHum and gHum.Health > 0) then return end

                -- Clamp the frame delta. Without this, one slow frame (a lag spike)
                -- at high speed produces a single huge jump, which reads as choppy /
                -- sticky. Capping at 1/30s keeps each step's distance consistent.
                local mdt = math.min(dt, 1 / 30)

                -- Old altitude control: WASD follow the camera's FULL direction, so
                -- looking up + W climbs and looking down + W descends (like a normal
                -- fly). Space/Ctrl still give direct up/down on top of that.
                local cf = Camera.CFrame
                local dir = Vector3.zero
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cf.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cf.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cf.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cf.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                    dir -= Vector3.new(0, 1, 0)
                end

                local pos = gHrp.Position
                if dir.Magnitude > 0 then
                    pos = pos + dir.Unit * GhostFlySpeed * mdt
                end

                -- Face the camera's flat (yaw-only) direction so the model stays
                -- upright and looks where you're looking, without tilting.
                local flatFace = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
                if flatFace.Magnitude > 0.01 then
                    gHrp.CFrame = CFrame.lookAt(pos, pos + flatFace.Unit)
                else
                    gHrp.CFrame = baseRot + pos
                end

                -- Kill any residual velocity so physics never tugs the body.
                gHrp.AssemblyLinearVelocity = Vector3.zero
                gHrp.AssemblyAngularVelocity = Vector3.zero
            end)

            library.notifications:create_notification({ name = "Tyranny.Exe", info = "Ghost Fly on — decoy left in place. Fly with WASD + Space/Ctrl, toggle off to teleport there.", lifetime = 7 })
        end,
    })

    -- Ghost Fly speed (studs/sec). Clone is client-only, so cranking this never
    -- flags the position check — only the final teleport back goes through the bypass.
    CharMods:AddSlider('GhostFlySpeed_TheBronx', {
        Text = 'Ghost Fly Speed', Default = 60, Min = 16, Max = 500, Rounding = 0, Suffix = ' spd',
        Callback = function(v) GhostFlySpeed = v end,
    })

    CharMods:AddToggle('ModifyJumpPower_TheBronx', {
        Text = 'Modify JumpPower', Default = false,
        Callback = function(state) Config.MiscSettings.ModifyJump.Enabled = state end,
    })

    library.flags['ClickTeleport_TheBronx'] = false
    CharMods:AddToggle('ClickTeleport_TheBronx', {
        Text = 'Click Teleport', Default = false,
        Callback = function(state) library.flags['ClickTeleport_TheBronx'] = state end,
    }):AddKeyPicker('ClickTeleportKey_TheBronx', {
        Default = 'LeftControl', Mode = 'Hold', Text = 'Click Teleport', NoUI = false,
    })
    BindKeyState(Options.ClickTeleportKey_TheBronx, function(state)
        Config.TheBronx.ClickTeleportActive = state
    end)

    CharMods:AddToggle('NoClip_TheBronx', {
        Text = 'No Clip', Default = false,
        Callback = function(state)
            if state then
                RunService:BindToRenderStep("NOCLIP", 1, function()
                    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                        if LocalPlayer.Character.Humanoid.Health ~= 0 then
                            for _, Value in LocalPlayer.Character:GetDescendants() do
                                if Collide_Data[Value.Name] then
                                    pcall(function() Value.CanCollide = false end)
                                end
                            end
                        end
                    end
                end)
            else
                RunService:UnbindFromRenderStep("NOCLIP")
                if LocalPlayer.Character then
                    for _, Value in LocalPlayer.Character:GetDescendants() do
                        if Collide_Data[Value.Name] then
                            pcall(function() Value.CanCollide = true end)
                        end
                    end
                end
            end
        end,
    })

    CharMods:AddSlider('JumpPowerValue_TheBronx', {
        Text = 'JumpPower Value', Default = 7, Min = 0, Max = 50, Rounding = 0, Suffix = '%',
        Callback = function(state) Config.MiscSettings.ModifyJump.Value = state end,
    })

end)

