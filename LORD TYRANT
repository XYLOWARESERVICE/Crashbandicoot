BuildSection('Extra', function()
    local Money = AF.Money

    -- ── Bank / ATM ──────────────────────────────────────────────────────
    -- Seed config defaults so the auto-loops have valid amounts before the
    -- inputs fire their callbacks.
    Config.TheBronx.WithdrawAmount = Config.TheBronx.WithdrawAmount or 90000
    Config.TheBronx.DepositAmount  = Config.TheBronx.DepositAmount  or 30000
    Config.TheBronx.MoneyAmount    = Config.TheBronx.MoneyAmount    or 10000

    Money:AddLabel('Bank / ATM')

    -- Live cash + bank balances. Both live under LocalPlayer.stored; we resolve
    -- whichever child holds each total (names vary by build), falling back to a
    -- name-contains scan.
    local CashLabel = Money:AddLabel('Cash Amount: $—', true)
    local BankLabel = Money:AddLabel('Bank Amount: $—', true)

    local function readCash()
        local stored = LocalPlayer:FindFirstChild("stored")
        if not stored then return nil end
        local v = stored:FindFirstChild("Money")
            or stored:FindFirstChild("Cash")
            or stored:FindFirstChild("Wallet")
        if not v then
            for _, c in ipairs(stored:GetChildren()) do
                if c:IsA("ValueBase") and (string.find(string.lower(c.Name), "cash") or string.lower(c.Name) == "money") then v = c break end
            end
        end
        if v and v:IsA("ValueBase") then return v.Value end
        return nil
    end
    local function readBank()
        local stored = LocalPlayer:FindFirstChild("stored")
        if not stored then return nil end
        local v = stored:FindFirstChild("Bank")
            or stored:FindFirstChild("BankMoney")
            or stored:FindFirstChild("Banked")
            or stored:FindFirstChild("BankAmount")
            or stored:FindFirstChild("StoredMoney")
        if not v then
            for _, c in ipairs(stored:GetChildren()) do
                if string.find(string.lower(c.Name), "bank") and c:IsA("ValueBase") then v = c break end
            end
        end
        if v and v:IsA("ValueBase") then return v.Value end
        return nil
    end
    task.spawn(function()
        while BankLabel do
            local cash = readCash()
            local bank = readBank()
            CashLabel:SetText('Cash Amount: $' .. (cash ~= nil and tostring(cash) or '—'))
            BankLabel:SetText('Bank Amount: $' .. (bank ~= nil and tostring(bank) or '—'))
