-- Build each UI section inside a guarded call. If one section errors, the
-- others still build (so the menu can never come up fully blank), and a
-- notification tells you exactly which section failed.
local function BuildSection(name, fn)
    local ok, err = pcall(fn)
    if not ok then
        warn("[Tyranny UI] Section '" .. name .. "' failed: " .. tostring(err))
        pcall(function()
            library.notifications:create_notification({ name = "UI Error", info = name .. ": " .. tostring(err), lifetime = 10 })
        end)
    end
end

