    local function RefreshPlayers()
        local Cache = {}
        for _, Player in ipairs(Players:GetPlayers()) do
            if Player ~= LocalPlayer then table.insert(Cache, Player.Name) end
        end
        table.sort(Cache)
        Options.SelectPlayer_TheBronx:SetValues(Cache)
    end

    -- Player list keeps itself up to date — no manual refresh button needed.
    task.spawn(RefreshPlayers)
    Players.PlayerAdded:Connect(RefreshPlayers)
    Players.PlayerRemoving:Connect(RefreshPlayers)

    -- ── Player money check (cash / bank / filthy stack) ─────────────────
    -- Reads the selected player's `stored` folder (same place LocalPlayer's
    -- Money/FilthyStack live). Works only if the game replicates `stored` to
    -- all clients; if it doesn't, it reports that the data isn't accessible.
    local function readPlayerMoney(plr)
        local stored = plr and plr:FindFirstChild("stored")
        if not stored then return nil end
        local function val(names)
            for _, n in ipairs(names) do
                local c = stored:FindFirstChild(n)
                if c and c:IsA("ValueBase") then return c.Value end
            end
            return nil
        end
        local cash  = val({ "Money", "Cash", "Wallet" })
        local bank  = val({ "Bank", "BankMoney", "Banked", "BankAmount", "StoredMoney" })
        local filth = val({ "FilthyStack", "Filthy", "FilthyMoney", "DirtyMoney" })
        if bank == nil then
            for _, c in ipairs(stored:GetChildren()) do
                if c:IsA("ValueBase") and string.find(string.lower(c.Name), "bank") then bank = c.Value break end
            end
        end
        return { cash = cash, bank = bank, filthy = filth }
    end

    local MoneyLabel = Opts:AddLabel('Select a player, then press Check Money.', true)
    Opts:AddButton({ Text = 'Check Player Money', Func = function()
        local name = Sel()
        local plr  = name and name ~= "nil" and Players:FindFirstChild(name)
        if not plr then
            MoneyLabel:SetText('No player selected.')
            return
        end
        local m = readPlayerMoney(plr)
        if not m then
            MoneyLabel:SetText(name .. ": money data isn't accessible (stored folder not replicated to clients).")
            return
        end
        local function fmt(v) return v ~= nil and ('$' .. tostring(v)) or 'n/a' end
        MoneyLabel:SetText(string.format('%s\nCash: %s\nBank: %s\nFilthy Stack: %s',
            name, fmt(m.cash), fmt(m.bank), fmt(m.filthy)))
        library.notifications:create_notification({
            name = name .. "'s Money",
            info = string.format("Cash %s  |  Bank %s  |  Filthy %s", fmt(m.cash), fmt(m.bank), fmt(m.filthy)),
            lifetime = 6,
        })
    end })

    -- Scans every player's stored money (cash + bank only) and picks the one
    -- holding the LEAST total, then auto-selects them in the dropdown so you can
    -- act on them right away. Skips players whose `stored` isn't replicated.
    Opts:AddButton({ Text = 'Find a Broke Fuck', Func = function()
        local poorest, poorestTotal, poorestBreak
        local scanned = 0
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            local m = readPlayerMoney(plr)
            if m then
                scanned += 1
                local total = (tonumber(m.cash) or 0) + (tonumber(m.bank) or 0)
                if not poorestTotal or total < poorestTotal then
                    poorest, poorestTotal, poorestBreak = plr, total, m
                end
            end
        end

        if not poorest then
            MoneyLabel:SetText('No accessible money data on any player (stored not replicated).')
            return
        end

        -- Auto-select them in the Select Player dropdown.
        pcall(function() Options.SelectPlayer_TheBronx:SetValue(poorest.Name) end)
        Config.TheBronx.PlayerUtilities.SelectedPlayer = poorest.Name

        local function fmt2(v) return v ~= nil and ('$' .. tostring(v)) or 'n/a' end
        MoneyLabel:SetText(string.format('Poorest: %s ($%d total)\nCash: %s\nBank: %s',
            poorest.Name, poorestTotal, fmt2(poorestBreak.cash), fmt2(poorestBreak.bank)))
        library.notifications:create_notification({
            name = "Poorest Player",
            info = string.format("%s has the least — $%d (cash+bank, scanned %d).", poorest.Name, poorestTotal, scanned),
            lifetime = 6,
        })
    end })

    Opts:AddToggle('SpectatePlayer_TheBronx', { Text = 'Spectate Player', Default = false,
        Callback = function(state) Config.TheBronx.PlayerUtilities.SpectatePlayer = state end })
    Opts:AddToggle('BringPlayer_TheBronx', { Text = 'Bring Player', Default = false,
        Callback = function(state) Config.TheBronx.PlayerUtilities.BringingPlayer = state end })
    Opts:AddToggle('AutoKillPlayer_TheBronx', { Text = 'Auto Kill Player - Gun', Default = false,
        Callback = function(state) Config.TheBronx.PlayerUtilities.AutoKill = state end })
    Opts:AddToggle('AutoRagdollPlayer_TheBronx', { Text = 'Auto Ragdoll Player - Gun', Default = false,
        Callback = function(state) Config.TheBronx.PlayerUtilities.AutoRagdoll = state end })

    Opts:AddButton({ Text = 'Teleport To Player', Func = function()
        local p = Players:FindFirstChild(Sel())
        if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            task.spawn(Teleport, p.Character.HumanoidRootPart.CFrame)
        end
    end })
    Opts:AddButton({ Text = 'Down Player - Hold Gun', Func = function()
        local p = Players:FindFirstChild(Sel())
        if p and p.Character and p.Character:FindFirstChild("Humanoid") then
            pcall(kill_gun, Sel(), "HumanoidRootPart", p.Character.Humanoid.Health - 5)
        end
    end })
    Opts:AddButton({ Text = 'Kill Player - Hold Gun', Func = function()
        pcall(kill_gun, Sel(), "HumanoidRootPart", math.huge)
    end })
    Opts:AddButton({ Text = 'God Player - Hold Gun', Func = function()
        pcall(kill_gun, Sel(), "HumanoidRootPart", math.sqrt(-1))
    end })
    Opts:AddButton({ Text = 'God All Players - Hold Gun', Func = function()
        task.spawn(function()
            for _, Value in Players:GetPlayers() do
                if Value ~= LocalPlayer and Value.Character and Value.Character:FindFirstChild("Humanoid")
                    and Value.Character.Humanoid.Health ~= 0 and not Value.Character:FindFirstChildOfClass("ForceField")
                    and Value.Character:FindFirstChild("HumanoidRootPart") then
                    pcall(kill_gun, Value.Name, "HumanoidRootPart", math.sqrt(-1))
                    task.wait(0.1)
                end
            end
        end)
    end })
    Opts:AddButton({ Text = 'Kill All Players - Hold Gun', Func = function()
        task.spawn(function()
            for _, Value in Players:GetPlayers() do
                if Value ~= LocalPlayer and Value.Character and Value.Character:FindFirstChild("Humanoid")
                    and Value.Character.Humanoid.Health ~= 0 and not Value.Character:FindFirstChildOfClass("ForceField")
                    and Value.Character:FindFirstChild("HumanoidRootPart") then
                    pcall(kill_gun, Value.Name, "HumanoidRootPart", math.huge)
                    task.wait(0.1)
                end
            end
        end)
    end })

    -- Dupe Actions box — lives on its own "Tyranny Lord" tab (next to Main).
    -- Its contents are filled in later by the TyrannyLord section.
    DupeActionsBox = Tabs.Lord:AddLeftGroupbox('Dupe Actions')

    -- Player Modifications — reuse the box created at the top of the right column
    -- (above Character Modifications); fall back if the Main section didn't build.
    local LocalMods = PlayerModsBox or Tabs.Main:AddRightGroupbox('Player Modifications')

    local __Modifications = {
        "Infinite Sleep", "Infinite Hunger", "Infinite Stamina", "Instant Interact",
        "Respawn faster", "Anti Lose Items", "Auto Pickup Cash", "Auto Pickup Bags",
        "Disable Camera Bobbing", "Disable Blood Effects", "Bypass Locked Cars",
        "No Jump Cooldown", "No Rent Pay", "No Fall Damage", "No Knockback",
        "Respawn Where You Died",
    }

    for _, Index in ipairs(__Modifications) do
        LocalMods:AddToggle('LPM_' .. Index:gsub(' ', ''), {
            Text = Index,
            Default = false,
            Callback = function(state)
                Config.TheBronx.PlayerModifications[Index:gsub(' ', '')] = state
            end,
        })
    end

    -- Toggle Interfaces — placed under Player Options (left column).
    local UIGroup = Tabs.Main:AddLeftGroupbox('Toggle Interfaces')

    local _UINames, BlacklistedNames = { 'ATM GUI' }, {
        "Dead", "Settings1", "Controls", "FirstShopGUI", "Freecam", "ThaShop2",
        "WATCH GUI", "NYPD Cars", "CONSTRUCTION LEVEL", "RobPlayerUI", "Bronx LOCKER",
        'MobileBeam', 'Settings', 'Flash', 'Enter', 'CopSirens',
    }

    for _, Value in LocalPlayer.PlayerGui:GetChildren() do
        if Value:IsA("ScreenGui") and not Value.Enabled then
            if not table.find(BlacklistedNames, Value.Name) then
                table.insert(_UINames, Value.Name)
            end
        end
    end

    UIGroup:AddDropdown('SelectedUI_TB3', {
        Values = _UINames, Default = 'Bronx Market 2', Text = 'Selected UI',
        Callback = function(v) library.flags['SelectedUI_TB3'] = v end,
