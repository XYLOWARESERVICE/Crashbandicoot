    library.flags['SelectedUI_TB3'] = Options.SelectedUI_TB3.Value

    UIGroup:AddToggle('UIEnabled_TB3', {
        Text = 'UI Enabled', Default = false,
        Callback = function(state)
            task.spawn(function()
                local selected = tostring(Options.SelectedUI_TB3.Value)

                if selected == "ATM GUI" then
