--  UI SETTINGS / MENU + CONFIG PERSISTENCE
-- =====================================================================
BuildSection('Settings', function()
    local TeleportService = game:GetService("TeleportService")
    local HttpService = game:GetService("HttpService")

    -- Executor HTTP request function (varies by executor)
    local _request = (syn and syn.request) or (http and http.request) or http_request or request

    local MenuGroup = Tabs.UISettings:AddLeftGroupbox('Menu')

    MenuGroup:AddLabel('Menu bind'):AddKeyPicker('MenuKeybind', {
        Default = 'RightShift', NoUI = true, Text = 'Menu keybind',
    })
    Library.ToggleKeybind = Options.MenuKeybind

    -- Shared queue_on_teleport reference + a clearer. On most executors a queued
    -- teleport script PERSISTS and re-runs on EVERY later teleport until it's
    -- overwritten — so once you press a "With Script" button, plain Rejoin / Server
    -- Hop / Join Lowest would ALSO reload the script. The plain (non-script) buttons
    -- call ClearTeleportQueue() first, which overwrites the queue with a no-op, so
    -- they teleport clean and only the "With Script" buttons reload the menu.
    local QueueTeleport = queue_on_teleport
        or (syn and syn.queue_on_teleport)
        or (fluxus and fluxus.queue_on_teleport)
        or queueonteleport
    local function ClearTeleportQueue()
        if QueueTeleport then pcall(function() QueueTeleport("") end) end
    end

    -- Unload — drop the load guard then tear the menu down. Wrapped so a failure
    -- in one cleanup step can't leave the button dead.
    MenuGroup:AddButton({ Text = 'Unload', Func = function()
        getgenv().loaded = false
        pcall(function() Library:Unload() end)
    end })

    MenuGroup:AddButton({ Text = 'Rejoin', Func = function()
        ClearTeleportQueue()
        pcall(function()
            TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId)
        end)
    end })

    -- Rejoin With Script — queues the loader to auto re-execute after the
    -- teleport (via queue_on_teleport), then rejoins. The menu reloads itself
    -- instead of you having to paste the script again.
    do
        local LOADER_LINK = "https://api.luarmor.net/files/v4/loaders/74b11e14499cf32a712a791e62191216.lua"

        -- Find queue_on_teleport regardless of executor.
        local queueteleport = queue_on_teleport
            or (syn and syn.queue_on_teleport)
            or (fluxus and fluxus.queue_on_teleport)
            or queueonteleport

        local function QueueScript()
            if not queueteleport or LOADER_LINK == "" then return false end
            local ok = pcall(function()
                queueteleport("loadstring(game:HttpGet('" .. LOADER_LINK .. "'))()")
            end)
            return ok
        end

        MenuGroup:AddButton({ Text = 'Rejoin With Script', Func = function()
            if not queueteleport then
                return library.notifications:create_notification({ name = "Tyranny.Exe", info = "Your executor has no queue_on_teleport — script can't auto-reload.", lifetime = 8 })
            end

            QueueScript()

            task.spawn(function()
                pcall(function()
                    -- Last player in the server can't teleport to the same instance,
                    -- so fall back to a fresh server.
                    if #Players:GetPlayers() <= 1 then
                        TeleportService:Teleport(game.PlaceId, LocalPlayer)
                    else
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
                    end
                end)
            end)
        end })
    end

    MenuGroup:AddButton({ Text = 'Join Lowest Server', Func = function()
        ClearTeleportQueue()
        task.spawn(function()
            local ok, err = pcall(function()
                local Url = string.format("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100", tostring(game.PlaceId))

                local function ListServers(cursor)
                    local Raw = game:HttpGet(Url .. ((cursor and "&cursor=" .. cursor) or ""))
                    return HttpService:JSONDecode(Raw)
                end

                local Server, Next
                repeat
                    local Servers = ListServers(Next)
                    Server = Servers.data[1]
                    Next = Servers.nextPageCursor
                until Server

                if Server.id == game.JobId then
                    return library.notifications:create_notification({ name = "Tyranny.Exe", info = "You are already in the smallest server!", lifetime = 8 })
                end

                TeleportService:TeleportToPlaceInstance(game.PlaceId, Server.id)
            end)
            if not ok then
                library.notifications:create_notification({ name = "Tyranny.Exe", info = "Join Lowest failed: " .. tostring(err), lifetime = 8 })
            end
        end)
    end })

    MenuGroup:AddButton({ Text = 'Server Hop', Func = function()
        ClearTeleportQueue()
        task.spawn(function()
            local ok, err = pcall(function()
                if not _request then
                    return library.notifications:create_notification({ name = "Tyranny.Exe", info = "Executor has no HTTP request function.", lifetime = 8 })
                end

                local Servers = {}
                local Request = _request({ Url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true", tostring(game.PlaceId)) })
                local Body = HttpService:JSONDecode(Request.Body)

                if Body and Body.data then
                    for _, Value in next, Body.data do
                        if type(Value) == "table" and tonumber(Value.playing) and tonumber(Value.maxPlayers)
                            and Value.playing < Value.maxPlayers and Value.id ~= game.JobId then
                            table.insert(Servers, 1, Value.id)
                        end
                    end
                end

                if #Servers == 0 then
                    return library.notifications:create_notification({ name = "Tyranny.Exe", info = "No open servers found to hop to.", lifetime = 8 })
                end

                TeleportService:TeleportToPlaceInstance(game.PlaceId, Servers[math.random(1, #Servers)])
            end)
            if not ok then
                library.notifications:create_notification({ name = "Tyranny.Exe", info = "Server Hop failed: " .. tostring(err), lifetime = 8 })
            end
        end)
    end })

    -- Server Hop With Script — queues the loader to auto re-run after the hop
    -- (via queue_on_teleport), then jumps to a different non-full server. The
    -- menu comes back on its own in the new server instead of you re-pasting it.
    do
        local SCRIPTS = {
            "https://api.luarmor.net/files/v4/loaders/74b11e14499cf32a712a791e62191216.lua",
        }

        local queueteleport = queue_on_teleport
            or (syn and syn.queue_on_teleport)
            or (fluxus and fluxus.queue_on_teleport)
            or queueonteleport

        -- Queue the loader directly when THIS button is pressed (not via a global
        -- OnTeleport hook). The old version connected LocalPlayer.OnTeleport, which
        -- fired on EVERY teleport — so the plain Rejoin / Server Hop / Join Lowest
        -- buttons also reloaded the script. Queueing inline here keeps script
        -- auto-reload exclusive to the "With Script" buttons.
        local function QueueScripts()
            if not queueteleport then return end
            for _, link in ipairs(SCRIPTS) do
                pcall(function()
                    queueteleport("loadstring(game:HttpGet('" .. link .. "'))()")
                end)
            end
        end

        MenuGroup:AddButton({ Text = 'Server Hop With Script', Func = function()
            task.spawn(function()
                if not queueteleport then
                    return library.notifications:create_notification({ name = "Tyranny.Exe", info = "Your executor has no queue_on_teleport — script can't auto-reload.", lifetime = 8 })
                end

                QueueScripts()

                local ok, err = pcall(function()
                    local Servers = {}
                    local Raw = game:HttpGet(string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true", tostring(game.PlaceId)))
                    local Body = HttpService:JSONDecode(Raw)

                    if Body and Body.data then
                        for _, Value in next, Body.data do
                            if type(Value) == "table" and tonumber(Value.playing) and tonumber(Value.maxPlayers)
                                and Value.playing < Value.maxPlayers and Value.id ~= game.JobId then
                                table.insert(Servers, 1, Value.id)
                            end
                        end
                    end

                    if #Servers == 0 then
                        return library.notifications:create_notification({ name = "Tyranny.Exe", info = "No open servers found to hop to.", lifetime = 8 })
                    end

                    TeleportService:TeleportToPlaceInstance(game.PlaceId, Servers[math.random(1, #Servers)], LocalPlayer)
                end)
                if not ok then
                    library.notifications:create_notification({ name = "Tyranny.Exe", info = "Server Hop With Script failed: " .. tostring(err), lifetime = 8 })
                end
            end)
        end })
    end

    -- Watermark — colorized to match the window title (RichText). Same approach:
    -- set the plain text, then find the watermark label and swap in a <font>-tagged
    -- version so the branding reads consistently across the whole menu.
    pcall(function()
        Library:SetWatermarkVisibility(true)
        Library:SetWatermark('Tyranny.Exe  |  Blood & Carnage')
    end)

    do
        local ORIGINAL = 'Tyranny.Exe  |  Blood & Carnage'
        -- Colored branding prefix (constant). FPS + ping segments are appended live.
        local BRAND =
            '<font color="rgb(255,255,255)">Tyranny.</font><font color="rgb(150,40,230)">Exe</font>'
            .. '  <font color="rgb(90,90,110)">|</font>  '
            .. '<font color="rgb(255,60,60)">Blood &amp; Carnage</font>'

        local SEP = '  <font color="rgb(90,90,110)">|</font>  '

        local Stats = game:GetService("Stats")

        -- Smoothed FPS from a rolling average of frame deltas.
        local fps, accum, frames = 60, 0, 0

        -- Builds the full RichText string for the current FPS / ping.
        local function Compose()
            local ping = 0
            pcall(function()
                ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue() + 0.5)
            end)

            -- Green > 60, yellow 30-60, red < 30.
            local fpsColor = (fps >= 60 and "rgb(85,255,127)") or (fps >= 30 and "rgb(255,210,80)") or "rgb(255,60,60)"
            -- Green < 100ms, yellow 100-200ms, red > 200ms.
            local pingColor = (ping < 100 and "rgb(85,255,127)") or (ping <= 200 and "rgb(255,210,80)") or "rgb(255,60,60)"

            return BRAND
                .. SEP .. string.format('<font color="rgb(180,180,190)">FPS:</font> <font color="%s">%d</font>', fpsColor, fps)
                .. SEP .. string.format('<font color="rgb(180,180,190)">Ping:</font> <font color="%s">%dms</font>', pingColor, ping)
        end

        task.spawn(function()
            -- Wait for the watermark label to exist, then drive it every frame.
            local label
            for _ = 1, 80 do
                local holders = { Library.ScreenGui, (gethui and gethui()) or nil, game:GetService("CoreGui") }
                for _, holder in ipairs(holders) do
                    if holder then
                        for _, d in ipairs(holder:GetDescendants()) do
                            if d:IsA("TextLabel") and d.Text == ORIGINAL then
                                label = d
                                break
                            end
                        end
                    end
                    if label then break end
                end
                if label then break end
                task.wait(0.1)
            end

            if not label then return end
            label.RichText = true

            -- The frame Linoria sizes for the watermark. Prefer the library's own
            -- reference; fall back to the label's parent frame.
            local frame = Library.Watermark or label.Parent

            RunService.RenderStepped:Connect(function(dt)
                -- Roll the FPS average roughly every 0.25s.
                accum += dt
                frames += 1
                if accum >= 0.25 then
                    fps = math.floor((frames / accum) + 0.5)
                    accum, frames = 0, 0
                end
                if label.Parent then
                    label.Text = Compose()
                    -- Grow the box to fit the rendered text. With RichText on,
                    -- TextBounds excludes the <font> markup, so this measures the
                    -- text you actually see. +12px keeps a little side padding.
                    if frame then
                        local bounds = label.TextBounds
                        frame.Size = UDim2.new(0, bounds.X + 12, frame.Size.Y.Scale, frame.Size.Y.Offset)
                    end
                end
            end)
        end)
    end
end)

