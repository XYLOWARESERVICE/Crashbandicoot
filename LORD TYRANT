            if char then
                -- Unanchor and teleport FIRST, while the camera is still on the
                -- clone at your scout spot. By the time we switch the camera to the
                -- real character, it's already arrived — no visible snap-back.
                for _, p in ipairs(char:GetDescendants()) do
                    if p:IsA("BasePart") then p.Anchored = false end
                end
                if teleportToClone and dest then
                    Teleport(dest)
                end
                local hum = char:FindFirstChildOfClass("Humanoid")
