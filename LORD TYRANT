-- Startup notification sequence (SleepyHub-style). Fired one after another so
-- they stack on screen as the script finishes loading.
task.spawn(function()
    local function notify(text, dur)
        pcall(function() Library:Notify(text, dur or 6) end)
    end

    local execName = "Unknown"
    pcall(function() execName = getexecutorname() end)

    local loadTime = os.clock() - (getgenv().__TyrannyStart or os.clock())

    notify(string.format("Tyranny.Exe - Compatible Executor detected (%s)", execName), 6)
    task.wait(0.45)
    notify(string.format("Welcome, thank you for using Tyranny.Exe - %s", LocalPlayer.Name), 6)
    task.wait(0.45)
    notify("Status: 🟢 Undetected (Safe to use)", 6)
    task.wait(0.45)
    notify("Tyranny.Exe - Bypassing main anti-cheat", 6)
    task.wait(0.45)
    notify(string.format("Script [Loaded] In - %.2fs", loadTime), 6)
    task.wait(0.45)
    notify("Tyranny.Exe - Successfully emulated detection", 6)

    -- Anti-cheat bypass noti chain (finale). Shows the REAL bypass duration:
    -- from script start (__TyrannyStart) to the moment the bypass was actually
    -- confirmed done (__TyrannyBypassDone, recorded right after the AntiCheatBypass
    -- wait loop). Falls back to total load time if the marker is missing.
    task.wait(0.6)
    notify("Tyranny.Exe - Bypassing anti-cheat...", 6)
    task.wait(1.4)
    local startT  = getgenv().__TyrannyStart or os.clock()
    local doneT   = getgenv().__TyrannyBypassDone or os.clock()
    local bypassTime = math.max(0, doneT - startT)
    notify(string.format("Anti-cheat bypassed ✅  in %.2fs  —  Become a 👑 TYRANT 👑", bypassTime), 7)
end)
