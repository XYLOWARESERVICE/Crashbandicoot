-- =====================================================================
--  ANTI REMOTE SPY
--  ---------------------------------------------------------------------
--  RemoteSpy tools (SimpleSpy, Hydroxide, etc.) capture remote traffic by
--  hooking either the __namecall metamethod or FireServer/InvokeServer via
--  hookfunction. Both of those only intercept the `:` namecall path.
--
--  Here we grab CLEAN, un-hooked copies of FireServer/InvokeServer (via
--  clonefunction) from throwaway instances, at the very top of the script —
--  before any spy could have loaded — and call them as PLAIN functions
--  (Fire(remote, ...) instead of remote:FireServer(...)). That bypasses the
--  namecall metamethod entirely, and the clone is immune to hookfunction on the
--  original method, so any remote routed through SecureFireServer/SecureInvokeServer
--  is invisible to a spy that hooks after us (the normal case: script first,
--  spy second). Route your proprietary remotes (kill_gun below) through these.
--
--  Limitation: if a spy is somehow loaded and hooks BEFORE this block runs, its
--  copy is the one we clone and protection is lost. Execute the script in a fresh
--  session (before any spy) for it to hold.
do
    local clone = clonefunction or function(f) return f end

    local ev = Instance.new("RemoteEvent")
    local rf = Instance.new("RemoteFunction")

    local rawFire   = clone(ev.FireServer)
    local rawInvoke = clone(rf.InvokeServer)

    ev:Destroy()
    rf:Destroy()

    -- Global so the deeply-nested backend (kill_gun, etc.) can reach them, matching
    -- how getgenv().Teleport / getgenv().kill_gun are exposed.
    getgenv().SecureFireServer = function(remote, ...)
        return rawFire(remote, ...)
    end
    getgenv().SecureInvokeServer = function(remote, ...)
        return rawInvoke(remote, ...)
    end
end

-- =====================================================================
--  ANTI REMOTE SPY — KICK ENFORCEMENT
--  ---------------------------------------------------------------------
--  Detects when a known RemoteSpy tool (SimpleSpy, Hydroxide, etc.) is
--  running alongside this script and KICKS the user with the message you
--  set below. Detection is by the spy's own fingerprints — the GUI window
--  it creates and the globals it exposes — NOT by scanning gc for the word
--  "spy" (that would match this script's own comments/strings and self-kick).
--
--  >>> EDIT THIS to change the kick message the spy user sees. Keep the
--      leading \n\n and trailing \n for the spaced/centered look. <<<
local ANTI_SPY_KICK_MESSAGE = "\n Spy detected — You Are Not Allowed To Spy On TYRANNY.EXE \n"

do
    local Plr = game:GetService("Players").LocalPlayer

    -- Distinctive name fragments of popular remote spies (lowercased). These are
    -- specific tool names, so they won't match this script's own GUIs/globals.
    -- Matched against every GUI Name (gethui/CoreGui/PlayerGui) and every
    -- getgenv() string key, so a spy is caught by the window OR the global it sets.
    --   • cobalt      -> ScreenGui "Cobalt" + getgenv().CobaltInitialized / .Cobalt
    --   • simplespy   -> ScreenGui "SimpleSpy" + getgenv().SimpleSpy (all variants)
    --   • hydroxide   -> ScreenGui "Hydroxide"
    --   • darkdex/dex -> Dark Dex explorer window
    --   • bizzyspy    -> BizzySpy window
    --   • generic remotespy / remote logger hubs
    local SPY_SIGNATURES = {
        "simplespy", "remotespy", "remote spy", "remote_spy",
        "hydroxide", "cobalt", "cobaltinitialized",
        "remotelogger", "remote logger", "spyremote",
        "bizzyspy", "darkdex", "dark dex",
    }

    local function matches(text)
        text = string.lower(tostring(text))
        for _, sig in ipairs(SPY_SIGNATURES) do
            if string.find(text, sig, 1, true) then return sig end
        end
        return nil
    end

    -- 1) Spy window: SimpleSpy/Hydroxide parent a ScreenGui with their name into
    --    gethui()/CoreGui/PlayerGui.
    local function scanGuis()
        local holders = {}
        pcall(function() if gethui then table.insert(holders, gethui()) end end)
        pcall(function() table.insert(holders, game:GetService("CoreGui")) end)
        pcall(function() table.insert(holders, Plr:FindFirstChild("PlayerGui")) end)
        for _, holder in ipairs(holders) do
            if holder then
                for _, d in ipairs(holder:GetChildren()) do
                    local sig = matches(d.Name)
                    if sig then return sig end
                end
            end
        end
        return nil
    end

    -- 2) Spy globals: SimpleSpy exposes getgenv().SimpleSpy (and similar).
    local function scanGlobals()
        local env = getgenv and getgenv()
        if type(env) ~= "table" then return nil end
        for k in pairs(env) do
            if type(k) == "string" then
                local sig = matches(k)
                if sig then return sig end
            end
        end
        return nil
    end

    -- Single kick path (fires once, guarded so nothing double-kicks).
    local kicked = false
    local function kick(reason)
        if kicked then return end
        kicked = true
        pcall(function() Plr:Kick(ANTI_SPY_KICK_MESSAGE) end)
    end

    -- INSTANT: fire the moment a spy GUI is parented. SimpleSpy/Hydroxide create
    -- their window as soon as they're injected, so a DescendantAdded listener on
    -- every GUI holder catches it on the same frame — no polling delay.
    local function watch(holder)
        if not holder then return end
        pcall(function()
            holder.DescendantAdded:Connect(function(d)
                if matches(d.Name) then kick() end
            end)
        end)
    end
    pcall(function() if gethui then watch(gethui()) end end)
    pcall(function() watch(game:GetService("CoreGui")) end)
    pcall(function() watch(Plr:FindFirstChild("PlayerGui")) end)
    -- PlayerGui can be replaced on respawn — re-hook the new one each time.
    pcall(function()
        Plr.ChildAdded:Connect(function(c)
            if c.Name == "PlayerGui" then watch(c) end
        end)
    end)

    -- Immediate scan too, in case the spy was already open before this ran.
    if scanGuis() or scanGlobals() then kick() end

    -- Fast fallback poll (0.5s) for spies that expose a global but no GUI, or
    -- whose GUI slipped past the event (rare). Stops once we've kicked.
    task.spawn(function()
        while not kicked and task.wait(0.5) do
            if scanGuis() or scanGlobals() then kick() end
        end
    end)
end

