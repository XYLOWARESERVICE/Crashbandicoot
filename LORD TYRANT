BuildSection('Teleports', function()
    -- Location first (top of the shared Teleports box), then Gun below.
    local TpGroup = AF.Teleports

    local TpList = {}
    for Index in Config.TheBronx.TeleportationList do table.insert(TpList, Index) end
    table.sort(TpList)

    -- Selecting a location just stores it now (no auto-teleport) so a wrong pick
    -- can be corrected before committing. Press the button below to actually go.
    TpGroup:AddDropdown('TeleportToPlace_TheBronx', {
        Values = TpList, Default = nil, Text = 'Location', AllowNull = true,
        Callback = function(state) Config.TheBronx.Selected_Location = state end,
    })

    TpGroup:AddButton({ Text = 'Teleport To Location', Func = function()
        task.spawn(function()
            local state = Config.TheBronx.Selected_Location
            if not state or state == "..." or not Config.TheBronx.TeleportationList[state] then
                return library.notifications:create_notification({ name = "Tyranny.Exe", info = "Select a location first.", lifetime = 5 })
            end
            Teleport(Config.TheBronx.TeleportationList[state])
            library.notifications:create_notification({ name = "Tyranny.Exe", info = "Teleported to " .. state .. "!", lifetime = 5 })
        end)
    end })

    local Buy = AF.Purchase

    Buy:AddDropdown('PurchaseSelectedItem_TheBronx', {
        Values = Config.Guns, Default = nil, Text = 'Gun', AllowNull = true,
        Callback = function(state)
            task.spawn(function()
                if not state then return end
                Config.TheBronx.Selected_Item = state

                local self = string.match(Config.TheBronx.Selected_Item, "^(.*) %-")
                if not self then return end
                self = self:match("^%s*(.-)%s*$")

                local GunModel = Workspace:FindFirstChild("GUNS") and Workspace.GUNS:FindFirstChild(self)
                if not GunModel then return end

                local OldCFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
                local Prompt = GunModel:FindFirstChildWhichIsA("ProximityPrompt", true)
                if not Prompt then return end

                if GunModel:FindFirstChild("GamepassID", true)
                    and not MarketplaceService:UserOwnsGamePassAsync(LocalPlayer.UserId, GunModel:FindFirstChild("GamepassID", true).Value) then
                    return library.notifications:create_notification({ name = "Tyranny.Exe", info = "You do not own this gamepass!", lifetime = 5 })
                end

                local Part = Prompt.Parent:IsA("BasePart") and Prompt.Parent.CFrame
                if LocalPlayer.stored.Money.Value < GunModel:FindFirstChild("Price", true).Value then
                    return library.notifications:create_notification({
                        name = "Tyranny.Exe",
                        info = string.format("You are $%d short.", GunModel:FindFirstChild("Price", true).Value - LocalPlayer.stored.Money.Value),
                        lifetime = 5,
                    })
                end

                task.spawn(Teleport, Part)
                task.wait(0.4)

                local ItemReceived = false
                task.spawn(function()
                    local Check = LocalPlayer.Backpack.ChildAdded:Connect(function(Child)
                        if tostring(Child) == tostring(self) then ItemReceived = true end
                    end)
                    task.spawn(function() task.wait(1.5) ItemReceived = true end)
                    repeat task.wait() until ItemReceived == true
                    Check:Disconnect()
                end)

                repeat task.wait() fireproximityprompt(Prompt) until ItemReceived == true
                task.wait(0.4)
                task.spawn(Teleport, OldCFrame)

                library.notifications:create_notification({ name = "Tyranny.Exe", info = "Successfully purchased " .. self .. "!", lifetime = 5 })
            end)
        end,
    })

end)

