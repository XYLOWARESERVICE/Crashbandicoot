    -- Count how many copies of a given tool name you actually own (backpack + held).
    local function CountGun(name)
        if not name then return 0 end
        local n = 0
        local Backpack = LocalPlayer:FindFirstChild("Backpack")
        if Backpack then
            for _, v in ipairs(Backpack:GetChildren()) do
                if v:IsA("Tool") and v.Name == name then n += 1 end
