                    local Character = Player.Character or Player.CharacterAdded:Wait()
                    local EquippedTool = Character:FindFirstChildOfClass("Tool")

                    -- Nothing equipped
                    if not EquippedTool then
                        task.wait(0.5)
                        continue
                    end

                    local ToolName = EquippedTool.Name
                    local DroppedCount = 0

                    -- Drop every copy of the equipped gun
                    while Config.DropAllGuns do
                        Character = Player.Character or Player.CharacterAdded:Wait()

                        local Tool =
                            Character:FindFirstChild(ToolName) or
                            Backpack:FindFirstChild(ToolName)

                        -- No more copies
                        if not Tool then
                            break
                        end

                        -- Equip from backpack if needed
                        if Tool.Parent == Backpack then
                            local Humanoid = Character:FindFirstChildOfClass("Humanoid")

                            if Humanoid then
                                Humanoid:EquipTool(Tool)
                                task.wait(0.2)
                            end

                            Tool = Character:FindFirstChild(ToolName)

                            if not Tool then
                                break
                            end
                        end

                        -- Drop tool
                        DropRemote:FireServer(Tool)

                        DroppedCount += 1

                        task.wait(0.25)
                    end

                    if DroppedCount > 0 then
                        library.notifications:create_notification({
                            name = "Xylo.Ware",
                            info = "Dropped " .. tostring(DroppedCount) .. " " .. ToolName .. "(s).",
                            lifetime = 5
                        })
                    end

                    task.wait(0.5)
                end

                Config.DropAllGunsRunning = false
            end)
        end
    end
})


