SafeActionsSection:toggle({
    name = "Auto Grab + Pass Held Gun",
    flag = "AutoGrabPassHeld",

    callback = function(state)

        Config.AutoGrabPass = state

        if not state then
            return
        end

        task.spawn(function()

            local Players =
                game:GetService("Players")

            local ReplicatedStorage =
                game:GetService("ReplicatedStorage")

            local TextChatService =
                game:GetService("TextChatService")

            local LocalPlayer =
                Players.LocalPlayer

            local BackpackRemote =
                ReplicatedStorage:WaitForChild(
                    "BackpackRemote"
                )

            --====================================================
            -- SCAN HELD GUN ONCE
            --====================================================

            local HeldTool =
                GetHeldTool()

            if not HeldTool then

                warn(
                    "NO GUN EQUIPPED"
                )

                Config.AutoGrabPass = false
                return
            end

            -- LOCK THIS GUN FOREVER

            local LockedToolName =
                HeldTool.Name

            print(
                "LOCKED GUN:",
                LockedToolName
            )

            --====================================================
            -- MAIN LOOP
            --====================================================

            while Config.AutoGrabPass do

                pcall(function()

                    if not SelectedPassPlayer then
                        task.wait(1)
                        return
                    end

                    local Character =
                        LocalPlayer.Character
                        or LocalPlayer.CharacterAdded:Wait()

                    local Backpack =
                        LocalPlayer:WaitForChild(
                            "Backpack"
                        )

                    local Humanoid =
                        Character:FindFirstChildOfClass(
                            "Humanoid"
                        )

                    if not Humanoid then
                        return
                    end

                    --====================================================
                    -- FIND ONLY LOCKED GUN
                    --====================================================

                    local LockedTool =
                        Character:FindFirstChild(
                            LockedToolName
                        )
                        or Backpack:FindFirstChild(
                            LockedToolName
                        )

                    --====================================================
                    -- IF TOOL MISSING, GRAB AGAIN
                    --====================================================

                    if not LockedTool then

                        pcall(function()

                            BackpackRemote:InvokeServer(
                                "Grab",
                                LockedToolName
                            )

                        end)

                        task.wait(0.2)

                        LockedTool =
                            Character:FindFirstChild(
                                LockedToolName
                            )
                            or Backpack:FindFirstChild(
                                LockedToolName
                            )
                    end

                    if not LockedTool then
                        return
                    end

                    --====================================================
                    -- FORCE EQUIP
                    --====================================================

                    Humanoid:EquipTool(
                        LockedTool
                    )

                    --====================================================
                    -- WAIT UNTIL FULLY EQUIPPED
                    --====================================================

                    local Equipped =
                        false

                    for i = 1, 40 do

                        local CurrentTool =
                            Character:FindFirstChildOfClass(
                                "Tool"
                            )

                        if CurrentTool
                        and CurrentTool.Name
                        == LockedToolName then

                            Equipped = true
                            break
                        end

                        -- KEEP TRYING

                        Humanoid:EquipTool(
                            LockedTool
                        )

                        task.wait(0.05)
                    end

                    --====================================================
                    -- IF NOT EQUIPPED SKIP
                    --====================================================

                    if not Equipped then

                        warn(
                            "FAILED TO EQUIP:",
                            LockedToolName
                        )

                        return
                    end

                    print(
                        "FULLY EQUIPPED:",
                        LockedToolName
                    )

                    --====================================================
                    -- PASS LOCKED GUN
                    --====================================================

                    local ChatEvents =
                        ReplicatedStorage
                            :FindFirstChild(
                                "DefaultChatSystemChatEvents"
                            )

                    if ChatEvents
                    and ChatEvents:FindFirstChild(
                        "SayMessageRequest"
                    ) then

                        ChatEvents
                            .SayMessageRequest
                            :FireServer(
                                "/passto " .. SelectedPassPlayer,
                                "All"
                            )

                    else

                        TextChatService
                            .TextChannels
                            .RBXGeneral
                            :SendAsync(
                                "/passto " .. SelectedPassPlayer
                            )
                    end

                    print(
                        "PASSED:",
                        LockedToolName,
                        "TO:",
                        SelectedPassPlayer
                    )

                    --====================================================
                    -- WAIT AFTER PASS
                    --====================================================

                    task.wait(0.35)

                    --====================================================
                    -- RE-GRAB SAME GUN
                    --====================================================

                    pcall(function()

                        BackpackRemote:InvokeServer(
                            "Grab",
                            LockedToolName
                        )

                    end)

                    task.wait(0.2)

                    --====================================================
                    -- RE-EQUIP SAME GUN
                    --====================================================

                    local ReEquip =
                        Character:FindFirstChild(
                            LockedToolName
                        )
                        or Backpack:FindFirstChild(
                            LockedToolName
                        )

                    if ReEquip then

                        Humanoid:EquipTool(
                            ReEquip
                        )

                        print(
                            "RE-EQUIPPED:",
                            LockedToolName
                        )
                    end

                end)

                --====================================================
                -- LOOP DELAY
                --====================================================

                task.wait(1.6)
            end
        end)
    end
})
