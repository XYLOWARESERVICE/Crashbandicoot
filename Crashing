                            repeat task.wait() until ItemReceieved == true
                            Check:Disconnect()
                        end)

                        repeat task.wait(); fireproximityprompt(Prompt); until ItemReceieved == true;
                        
                        task.wait(0.4)

                        task.spawn(Teleport, OldCFrame)

