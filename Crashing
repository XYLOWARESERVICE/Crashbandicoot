SafeActionsSection:toggle({
    name = "Buy Back Listed Items",
    flag = "BuyBackListedItems",
    default = false,
    callback = function(state)
        Config.BuyBackListedItems = state

        if state then
            task.spawn(function()
                local SavedItems = {}  -- Using local table

                while Config.BuyBackListedItems do
                    local Player = Players.LocalPlayer
                    local Character = Player.Character or Player.CharacterAdded:Wait()

                    if not Character or not Character:FindFirstChild("Humanoid") then
                        task.wait(1)
                        continue
                    end

                    -- Build a list of all unique item names currently listed by you
                    table.clear(SavedItems)

                    for _, v in pairs(ReplicatedStorage.MarketItems:GetDescendants()) do
                        if v:IsA("StringValue")
                            and v.Name == "owner"
                            and v.Value == Player.Name
                            and v.Parent
                            and v.Parent:IsA("Instance") then

                            local itemName = v.Parent.Name

                            -- Avoid duplicates
                            if not table.find(SavedItems, itemName) then
                                table.insert(SavedItems, itemName)
                            end
                        end
                    end

                    if #SavedItems == 0 then
                        task.wait(1)
                        continue
                    end

                    local BuyItemRemote = ReplicatedStorage:WaitForChild("BuyItemRemote")
                    local BoughtCount = 0

                    task.wait(0.5)

                    repeat
                        for i = #SavedItems, 1, -1 do
                            -- Stop immediately if toggle is turned off
                            if not Config.BuyBackListedItems then
                                break
                            end

                            local gunName = SavedItems[i]

                            if Character.Humanoid.Health == 0 then
                                break
                            end

                            local toolIds = {}

                            -- Find every SpecialId for this item that belongs to you
                            for _, v in pairs(ReplicatedStorage.MarketItems:GetDescendants()) do
                                if v:IsA("StringValue")
                                    and v.Name == "owner"
                                    and v.Value == Player.Name
                                    and v.Parent
                                    and v.Parent.Name == gunName then
                                    table.insert(toolIds, v.Parent:GetAttribute("SpecialId"))
                                end
                            end

                            -- Buy back all listings for this item
                            while #toolIds > 0 and Config.BuyBackListedItems do
                                for _, id in ipairs(toolIds) do
                                    if not Config.BuyBackListedItems then
                                        break
                                    end

                                    if Character.Humanoid.Health == 0 then
                                        break
                                    end

                                    BuyItemRemote:FireServer(gunName, "Remove", id)
                                    BoughtCount += 1
                                    task.wait(2.5)
                                end

                                -- Re-scan until none remain
                                table.clear(toolIds)

                                for _, v in pairs(ReplicatedStorage.MarketItems:GetDescendants()) do
                                    if v:IsA("StringValue")
                                        and v.Name == "owner"
                                        and v.Value == Player.Name
                                        and v.Parent
                                        and v.Parent.Name == gunName then
                                        table.insert(toolIds, v.Parent:GetAttribute("SpecialId"))
                                    end
                                end
                            end

                            -- Remove processed item
                            table.remove(SavedItems, i)
                        end

                        task.wait(0.5)
                    until
                        #SavedItems == 0
                        or Character.Humanoid.Health == 0
                        or not Config.BuyBackListedItems

                    if BoughtCount > 0 then
                        library.notifications:create_notification({
                            name = "Xylo.Ware",
                            info = "Bought back " .. tostring(BoughtCount) .. " listed item(s).",
                            lifetime = 5
                        })
                    end

                    -- Wait before checking for newly listed items again
                    task.wait(1)
                end
            end)
        end
    end
})

